{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9090/api/events",
            "headers": { "Content-Type": "application/json" }
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9090/api/events",
            "headers": { "Content-Type": "application/json" }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9090/api/events",
            "headers": { "Content-Type": "application/json" }
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9090/api/events",
            "headers": { "Content-Type": "application/json" }
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9090/api/events",
            "headers": { "Content-Type": "application/json" }
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:9090/api/events",
            "headers": { "Content-Type": "application/json" }
          }
        ]
      }
    ]
  }
}
